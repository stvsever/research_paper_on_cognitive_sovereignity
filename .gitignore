# Keep tracked manuscript outputs and tracked report assets.
# Do not ignore `research_report/assets/` because the committed manuscript source
# references those figure/table files directly. Untracking them would break a
# clean LaTeX rebuild from the repository alone.
!research_report/report/main.tex
!research_report/report/main.pdf
!research_report/report/references.bib

# Generated interactive visualization HTML outputs are kept locally but not tracked
evaluation/**/visuals/**/*.html
evaluation/**/stage_outputs/07_generate_research_visuals/**/*.html
evaluation/**/stage_checks/**/*.html

# Reproduction scripts — run locally, not tracked
scripts/

