{
  "_metadata": {
    "adversarial_operator_goal": "Maximize aggregate erosion of defense infrastructure, multilateral alliance cohesion, institutional security capacity, and the epistemic trust required to coordinate a collective response, through targeted cyber-manipulation of public opinion.",
    "adversarial_operator_description": "A state-level or sophisticated non-state adversarial operator whose strategic objective is to weaken the target population's collective willingness and institutional capacity for coordinated defense, deterrence, and security governance. The operator profits from any opinion movement that reduces societal support for the security architecture, amplifies internal societal fragmentation, or degrades the epistemic/informational integrity on which deliberative governance depends. This framing is used for research purposes to model directionally aligned susceptibility in cyber-manipulation simulation studies.",
    "direction_convention": {
      "+1": "Adversary seeks to INCREASE this opinion score; a higher score on this leaf serves the adversary's strategic goal.",
      "-1": "Adversary seeks to DECREASE this opinion score; a lower score serves the adversary's strategic goal.",
      "0": "Directionally ambiguous with respect to this adversary's stated goal: the leaf is included for ontological completeness and opinion diversity but is not assigned a clear exploitation direction. It is excluded from adversarially-aligned effectivity scoring and treated as a non-target leaf."
    },
    "domain_notes": {
      "Information_Integrity_and_Platforms": "Opinions about information ecosystem governance, platform accountability, media trust, and the epistemic infrastructure of democratic deliberation — directly downstream of the adversary's second-order goal of eroding epistemic trust. Several leaves in this domain are deliberately direction-assigned so that successful manipulation is scoreable."
    }
  },
